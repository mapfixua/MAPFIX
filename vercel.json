{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "public/**",
          "data.json",
          "orders.json",
          "favorites.json",
          "server.js",
          "paths.js",
          "auth-jwt.js",
          "supabaseClient.js",
          "catalog-data.js",
          "search-ai.js"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/index.js"
    }
  ]
}
